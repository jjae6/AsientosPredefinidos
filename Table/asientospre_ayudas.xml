<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
    </column>
    <column>
        <name>idasientopre</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>cuando</name>
        <type>text</type>
    </column>
    <column>
        <name>ejemplo</name>
        <type>text</type>
    </column>
    <column>
        <name>nota</name>
        <type>text</type>
    </column>

    <constraint>
        <name>asientospre_ayudas_pkey</name>
        <type>PRIMARY KEY (id)</type>
