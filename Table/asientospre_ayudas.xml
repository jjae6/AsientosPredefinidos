    <constraint>
        <name>uniq_asientospre_ayudas_idasientopre</name>
        <type>UNIQUE (idasientopre)</type>
    </constraint>

    <constraint>
        <name>ca_asientospre_ayudas_asientospre</name>
        <type>FOREIGN KEY (idasientopre) REFERENCES asientospre (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
